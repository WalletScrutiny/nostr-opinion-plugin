{
	"name": "nostr-opinion",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "rm -f index.html && ln -s index.staging.html index.html && vite",
		"build": "vite build",
		"build:summariser": "esbuild ./src/summariser.ts --bundle --platform=node --target=node18 --outfile=./dist/nostr-opinion-summariser.js --format=cjs",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"prepare": "husky install",
		"lint": "eslint src --fix",
		"format": "prettier src --write",
		"deploy:staging": "rm -f .env.local && ln -s .env.staging .env.local && rm -f index.html && ln -s index.staging.html index.html && ./bin/deploy.sh",
		"deploy:production": "rm -f .env.local && ln -s .env.production .env.local && rm -f index.html && ln -s index.production.html index.html && npm run build && cp index.html ./dist && ./bin/deploy.sh"
	},
	"devDependencies": {
		"@esbuild/linux-x64": "^0.28.1",
		"@eslint/js": "^10.0.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^25.9.4",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.61.0",
		"autoprefixer": "^10.5.2",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-svelte": "^3.19.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"nostr-tools": "^2.23.8",
		"postcss": "^8.5.15",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^3.4.19",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0"
	},
	"dependencies": {
		"@drenso-toast-ui/editor": "^3.4.1",
		"@nostr-dev-kit/ndk": "2.15.2",
		"@nostr-dev-kit/ndk-cache-dexie": "2.6.44",
		"@nostr-dev-kit/ndk-svelte": "2.4.48",
		"@void-cat/api": "^1.0.10",
		"dompurify": "^3.4.11",
		"ws": "^8.21.0"
	},
	"overrides": {
		"sjcl": "1.0.9"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": "eslint src --fix",
		"*.{json,js,ts,svelte,html}": "prettier src --write --ignore-unknown"
	}
}
